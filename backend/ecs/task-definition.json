{
  "family": "cometahub-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::833333701392:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::833333701392:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "cometahub-backend",
      "image": "833333701392.dkr.ecr.us-east-1.amazonaws.com/cometahub-backend:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 3000, "protocol": "tcp" }],
      "environment": [
        { "name": "PORT", "value": "3000" },
        { "name": "DB_DATABASE", "value": "cometahub" },
        { "name": "DB_PORT", "value": "3306" },
        { "name": "CORS_ORIGIN", "value": "https://app.cometahub.com" },
        { "name": "JWT_EXPIRES_IN", "value": "7d" }
      ],
      "secrets": [
        { "name": "DB_HOST", "valueFrom": "arn:aws:secretsmanager:us-east-1:833333701392:secret:loterix/db-app-lQdopE:DB_HOST::" },
        { "name": "DB_USERNAME", "valueFrom": "arn:aws:secretsmanager:us-east-1:833333701392:secret:loterix/db-app-lQdopE:DB_USERNAME::" },
        { "name": "DB_PASSWORD", "valueFrom": "arn:aws:secretsmanager:us-east-1:833333701392:secret:loterix/db-app-lQdopE:DB_PASSWORD::" },
        { "name": "JWT_SECRET", "valueFrom": "arn:aws:secretsmanager:us-east-1:833333701392:secret:cometahub/jwt-fmlOIe:JWT_SECRET::" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cometahub-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
