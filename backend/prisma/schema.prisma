// =========================================================================
// SCHEMA PRISMA — CometaHub
// Banco: MySQL (AWS RDS compartilhado `bichomaster-db`, schema `cometahub`).
// A DATABASE_URL é montada a partir de DB_HOST/DB_USERNAME/DB_PASSWORD/
// DB_DATABASE (ver src/config/env.js) — mesmo padrão de secrets da infra.
// Obs.: usamos String + valores validados no código (sem enums nativos).
// =========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Usuário do painel interno (equipe da agência).
model User {
  id          String   @id @default(cuid())
  nome        String   @db.VarChar(191)
  email       String   @unique @db.VarChar(191)
  senha       String // hash bcrypt
  role        String   @default("colaborador") @db.VarChar(20) // admin | colaborador
  // Módulos que o colaborador enxerga (CSV de chaves: "projetos,financeiro").
  // Ignorado para admin (admin vê tudo). Ver src/config/modules.js.
  permissions String   @default("") @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Projeto da agência.
model Project {
  id          String       @id @default(cuid())
  nome        String       @db.VarChar(191)
  cliente     String       @default("") @db.VarChar(191)
  descricao   String       @default("") @db.VarChar(2000)
  status      String       @default("ativo") @db.VarChar(30) // ativo | pausado | concluido
  dataInicio  String       @default("") // "YYYY-MM-DD"
  dataFim     String       @default("") // "YYYY-MM-DD"
  obligations Obligation[]
  routines    Routine[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

// Obrigação (item do roadmap de um projeto).
model Obligation {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titulo          String   @db.VarChar(191)
  descricao       String   @default("") @db.VarChar(2000)
  responsavel     String   @default("") @db.VarChar(191) // nome (snapshot)
  responsavelEmail String  @default("") @db.VarChar(191) // e-mail do responsável
  prazo       String   @default("") @db.VarChar(10) // "YYYY-MM-DD"
  prioridade  String   @default("media") @db.VarChar(20) // baixa | media | alta
  status      String   @default("pendente") @db.VarChar(20) // pendente | em_andamento | concluido
  ordem       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

// Rotina/serviço recorrente da empresa (agenda). Ex.: "todo dia enviar msg",
// "toda quarta e sábado fazer sorteio".
model Routine {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titulo      String   @db.VarChar(191)
  descricao   String   @default("") @db.VarChar(2000)
  horario     String   @default("") @db.VarChar(5) // "HH:MM" (opcional)
  // Tipo de recorrência: diaria | semanal | mensal | unica
  tipo        String   @default("semanal") @db.VarChar(20)
  diasSemana  String   @default("") @db.VarChar(20) // CSV 0..6 (0=Dom) p/ semanal
  diaMes      Int?     // dia do mês (1..31) p/ mensal
  data        String   @default("") @db.VarChar(10) // "YYYY-MM-DD" p/ tipo unica
  dataInicio  String   @default("") @db.VarChar(10) // início da validade (opcional)
  dataFim     String   @default("") @db.VarChar(10) // fim da validade (opcional)
  cor         String   @default("#e10600") @db.VarChar(9)
  ativo       Boolean  @default(true)
  completions RoutineCompletion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}

// Registro de execução de uma rotina num dia específico (feito/pendente).
model RoutineCompletion {
  id        String   @id @default(cuid())
  routineId String
  routine   Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  data      String   @db.VarChar(10) // "YYYY-MM-DD" da ocorrência
  status    String   @default("concluido") @db.VarChar(20) // concluido | pendente
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([routineId, data])
  @@index([routineId])
}
