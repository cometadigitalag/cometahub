# Porta da API (local 4000; em produção/ECS o padrão da infra é 3000)
PORT=4000

# Origem permitida (frontend do painel) para CORS. Em produção, a URL do painel.
CORS_ORIGIN=*

# --- Banco (MySQL / AWS RDS compartilhado) ---
# Padrão da infra: DB_HOST/DB_USERNAME/DB_PASSWORD vêm do Secrets Manager
# (loterix/db-app) e DB_DATABASE é o schema deste sistema.
# A DATABASE_URL é montada automaticamente a partir destas partes (env.js).
DB_HOST=bichomaster-db.csx6yysay70e.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USERNAME=loterix_app
DB_PASSWORD=
DB_DATABASE=cometahub
# Alternativa: definir a URL completa direto (tem prioridade sobre as partes)
# DATABASE_URL="mysql://user:senha@host:3306/cometahub"

# Segredo do JWT (em produção: Secrets Manager cometahub/jwt)
JWT_SECRET="troque-este-segredo-por-um-valor-aleatorio-longo"
JWT_EXPIRES_IN="7d"

# Credenciais do admin criado no seed (primeiro acesso)
SEED_ADMIN_NOME="Administrador"
SEED_ADMIN_EMAIL="cometadigitalag@gmail.com"
SEED_ADMIN_SENHA="cometa123"
