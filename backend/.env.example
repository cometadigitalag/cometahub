# Porta da API
PORT=4000

# Origem permitida (frontend do admin) para CORS
CORS_ORIGIN=http://localhost:5174

# Banco de dados.
# AGORA (local): SQLite em arquivo.
DATABASE_URL="file:./dev.db"
# DEPOIS (AWS RDS PostgreSQL): trocar provider no schema.prisma para "postgresql"
# e usar algo como:
# DATABASE_URL="postgresql://usuario:senha@host-rds.amazonaws.com:5432/cometahub?schema=public"

# Segredo do JWT (troque por um valor longo e aleatório em produção)
JWT_SECRET="troque-este-segredo-por-um-valor-aleatorio-longo"
JWT_EXPIRES_IN="7d"

# Credenciais do admin criado no seed (primeiro acesso)
SEED_ADMIN_NOME="Administrador"
SEED_ADMIN_EMAIL="cometadigitalag@gmail.com"
SEED_ADMIN_SENHA="cometa123"
